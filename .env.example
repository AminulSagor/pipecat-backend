# my-voice-bot - Environment Variables
# Copy this file to .env and fill in your API keys



# OpenAI (STT/LLM/TTS/Realtime)
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_VOICE_ID= # "alloy"

# LiveKit Cloud
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_ROOM_NAME=voice-room
LIVEKIT_TOKEN_TTL_SECONDS=900
LIVEKIT_BOT_IDENTITY=voice-bot
# Optional: provide pre-minted worker token instead of API key/secret minting
LIVEKIT_BOT_TOKEN=
LIVEKIT_BOT_TOKEN_TTL_SECONDS=3600

# Token API server binding (Railway sets PORT automatically)
HOST=0.0.0.0
PORT=7860

# Bot pipeline behavior
PIPELINE_IDLE_TIMEOUT_SECS=0

