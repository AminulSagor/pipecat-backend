# my-voice-bot - Environment Variables
# Copy this file to .env and fill in your API keys



# OpenAI (STT/LLM/TTS/Realtime)
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_VOICE_ID= # "alloy"

# LiveKit Cloud
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_ROOM_NAME=voice-room
LIVEKIT_TOKEN_TTL_SECONDS=900

# Server binding (Railway sets PORT automatically)
HOST=0.0.0.0
PORT=7860

